{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "chat.accelim.ai" }],
      "destination": "http://129.121.113.58/:path*"
    },
    {
      "source": "/embed.min.js",
      "destination": "http://129.121.113.58/embed.min.js"
    },
    {
      "source": "/chatbot/:path*",
      "destination": "/api/dify-chatbot?slug=:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "http://129.121.113.58/_next/:path*"
    },
    {
      "source": "/console/:path*",
      "destination": "http://129.121.113.58/console/:path*"
    },
    {
      "source": "/api/:path((?!contact$|intake$|dify-chatbot$).*)",
      "destination": "http://129.121.113.58/api/:path*"
    },
    {
      "source": "/manifest.json",
      "destination": "http://129.121.113.58/manifest.json"
    },
    {
      "source": "/icon-192x192.png",
      "destination": "http://129.121.113.58/icon-192x192.png"
    },
    {
      "source": "/icon-512x512.png",
      "destination": "http://129.121.113.58/icon-512x512.png"
    },
    {
      "source": "/apple-touch-icon.png",
      "destination": "http://129.121.113.58/apple-touch-icon.png"
    },
    {
      "source": "/logo/:path*",
      "destination": "http://129.121.113.58/logo/:path*"
    },
    {
      "source": "/files/:path*",
      "destination": "http://129.121.113.58/files/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
