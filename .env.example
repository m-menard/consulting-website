# =========================================
# AcceLLM Marketing Site (Vercel)
# =========================================
# Frontend: set VITE_* in Vercel → Environment Variables (build time).
# API routes: set server vars below in Vercel (runtime).
# NEVER commit .env to version control.
#
# Local dev: `npm run dev` starts Vite (5173) + API server (3000).
# Copy this file to .env and fill in Google Sheets + SMTP for forms to work.
# =========================================

# --- Public site (VITE_ prefix, baked into the client build) ---
VITE_APP_NAME=AcceLLM
VITE_APP_TAGLINE=Design, build, and deploy production-grade AI systems.
VITE_LOGO_URL_LIGHT=/logo-dark.png
VITE_LOGO_URL_DARK=/logo-light.png
VITE_FAVICON_URL=/favicon.png
# VITE_SOCIAL_LINKEDIN_URL=https://linkedin.com/company/your-co
# VITE_CANONICAL_BASE_URL=https://accelim.ai
# VITE_SEO_TITLE=
# VITE_SEO_DESCRIPTION=
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXX

# Dify chatbot (proxied on accelim.ai — see vercel.json + middleware.ts)
VITE_DIFY_TOKEN=7V3S2LdZRwOQ8EvT
# VITE_DIFY_BASE_URL=https://accellm.ai
# DIFY_UPSTREAM_URL=http://185.238.250.203

# --- Intake form → Google Sheets (Vercel serverless /api/intake) ---
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# Or:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_TAB_NAME=Information

# --- Contact form email (Vercel serverless /api/contact) ---
APP_NAME=AcceLLM
ADMIN_EMAIL=you@accelim.ai
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=notifications@accelim.ai
