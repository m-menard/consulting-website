# =========================================
# AgentLabs - Environment Variables Template
# =========================================
# 
# QUICK START:
# 1. Copy this file: cp .env.example .env
# 2. Run setup: npm run setup (auto-generates security secrets)
# 3. Fill in the remaining values below
# 4. Initialize database: npm run db:push && npm run db:seed
# 5. Start: npm run build && npm run start
#
# NEVER commit .env to version control!
# =========================================

# =========================================
# Database Configuration
# =========================================
PGHOST=postgres
PGPORT=5432
PGUSER=agentlabs
PGPASSWORD=your_secure_database_password_here
PGDATABASE=agentlabs
DATABASE_URL=postgresql://agentlabs:your_secure_database_password_here@postgres:5432/agentlabs


# =========================================
# Application Configuration
# =========================================
NODE_ENV=production
PORT=5000
APP_PORT=5000
APP_URL=https://yourdomain.com
APP_DOMAIN=yourdomain.com
BASE_URL=https://yourdomain.com

# Logging level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Demo Mode: Set to true to create a demo account with sample data
# Demo account: demo@diploy.in / Demo@123 (admin role, pro plan, 1000 credits)
# Seeds: 3 agents, 4 KB items, 3 campaigns, 18 contacts, 11 call records,
#         5 credit transactions, 2 webhooks, 1 widget, 4 jobs, 12 candidates
DEMO_MODE=false

# =========================================
# Security Secrets (Auto-generated by: npm run setup)
# =========================================
# These are automatically generated when you run: npm run setup
# Do not modify manually - just run the setup command

# Session encryption key (64 characters)
SESSION_SECRET=WILL_BE_AUTO_GENERATED_BY_SETUP

# JWT signing key for authentication tokens (64 characters)
JWT_SECRET=WILL_BE_AUTO_GENERATED_BY_SETUP

# =========================================
# Twilio Configuration
# =========================================
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# =========================================
# ElevenLabs Configuration
# =========================================
# Get from: https://elevenlabs.io/app/settings/api-keys
# Note: You can add multiple keys via the admin panel after installation
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# =========================================
# Stripe Configuration (Production)
# =========================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================
# Stripe Configuration (Testing - Optional)
# =========================================
# For testing in production environment
TESTING_STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TESTING_VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================
# SMTP Email Configuration
# =========================================
# Required for OTP email verification during user signup
# Gmail example (you can use any SMTP provider):
# 1. Go to Google Account Settings
# 2. Enable 2-Step Verification
# 3. Generate an "App Password" for "Mail"
# Other providers: SendGrid, Mailgun, AWS SES, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM_EMAIL=noreply@yourdomain.com

# =========================================
# OpenAI Configuration (Optional)
# =========================================
# Required for Plivo+OpenAI and Twilio+OpenAI voice engines
# Get from: https://platform.openai.com/api-keys
# Note: Can also be configured via Admin Panel > OpenAI Pool
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================
# Razorpay Configuration (Optional - India)
# =========================================
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# =========================================
# PayPal Configuration (Optional)
# =========================================
# Get from: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# =========================================
# Paystack Configuration (Optional - Africa)
# =========================================
# Get from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================================
# MercadoPago Configuration (Optional - LatAm)
# =========================================
# Get from: https://www.mercadopago.com/developers/panel/credentials
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token_here

# =========================================
# Webhook Secrets (Optional - for signature verification)
# =========================================
# These provide additional security for webhook endpoints
# Auto-generated if not set, but should be persisted for production
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_WEBHOOK_SECRET=your_elevenlabs_webhook_secret_here

# =========================================
# Client Intake Form → Google Sheets
# =========================================
# 1. Enable Google Sheets API in Google Cloud
# 2. Create a service account and download JSON key to secrets/ (gitignored)
# 3. Share the spreadsheet with the service account email as Editor
#
# GOOGLE_APPLICATION_CREDENTIALS=secrets/accellm-project-service-account.json
# GOOGLE_SHEETS_SPREADSHEET_ID=1B7mr3vtUZIl5kuzcK0GokCrqGhzaDJFT4sDAkRSS5QQ
# Share sheet with: data-save-bot@accellm-project.iam.gserviceaccount.com
# GOOGLE_SHEETS_TAB_NAME=Information
# Omit to auto-use the spreadsheet's first tab
#
# Alternatives: GOOGLE_APPLICATION_CREDENTIALS_JSON (single-line JSON) or
# GOOGLE_SERVICE_ACCOUNT_EMAIL + GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY

# =========================================
# Installation Configuration
# =========================================
# SKIP_INSTALLER=true — local dev only: skip /install redirect (use landing + intake without DB)
# Set SKIP_INSTALLER=false in production and complete the installer at /install
SKIP_INSTALLER=false
INSTALLER_COMPLETED=false
INSTALLER_VERSION=1.0.0
