            },
            "url": {
              "raw": "{{base_url}}/api/v1/campaigns/:id/contacts",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "campaigns", ":id", "contacts"],
              "variable": [
                {
                  "key": "id",
                  "value": "campaign-uuid-here"
                }
              ]
            },
            "description": "Add contacts to a campaign"
          }
        },
        {
          "name": "Start Campaign",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/campaigns/:id/start",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "campaigns", ":id", "start"],
              "variable": [
                {
                  "key": "id",
                  "value": "campaign-uuid-here"
                }
              ]
            },
            "description": "Start executing a campaign"
          }
        },
        {
          "name": "Pause Campaign",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/campaigns/:id/pause",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "campaigns", ":id", "pause"],
              "variable": [
                {
                  "key": "id",
                  "value": "campaign-uuid-here"
                }
              ]
            },
            "description": "Pause a running campaign"
          }
        }
      ]
    },
