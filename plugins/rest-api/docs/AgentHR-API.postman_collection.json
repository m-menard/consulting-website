{
  "info": {
    "_postman_id": "agenthr-rest-api-v1",
    "name": "AgentHR REST API",
    "description": "Complete API collection for AgentHR AI-powered bulk calling platform.\n\n## Authentication\n\nAll endpoints require an API key. Add your key to the collection variables:\n1. Click on the collection name\n2. Go to Variables tab\n3. Set `api_key` to your API key\n\n## Getting Started\n\n1. Generate an API key from Settings > Developer in the AgentHR dashboard\n2. Set the `base_url` variable to your instance URL\n3. Set your `api_key`\n4. Start making requests!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_key}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-agenthr-instance.com",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "your-api-key-here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Info",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "Check API health status (no authentication required)"
          }
        },
        {
          "name": "API Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1"]
            },
            "description": "Get API information and available endpoints"
          }
        }
      ]
    },
    {
      "name": "Calls",
      "item": [
        {
          "name": "Trigger Call",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agentId\": \"your-agent-uuid\",\n  \"toNumber\": \"+14155551234\",\n  \"fromNumber\": \"+14155555678\",\n  \"engine\": \"elevenlabs\",\n  \"metadata\": {\n    \"source\": \"api\",\n    \"campaign\": \"demo\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/calls",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calls"]
            },
            "description": "Initiate a new outbound call"
          }
        },
        {
          "name": "List Calls",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/calls?page=1&pageSize=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calls"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                }
              ]
            },
            "description": "Get paginated list of all calls"
          }
        },
        {
          "name": "Get Call Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/calls/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calls", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "call-uuid-here"
                }
              ]
            },
            "description": "Get detailed information about a specific call"
          }
        },
        {
          "name": "Hangup Call",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/calls/:id/hangup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calls", ":id", "hangup"],
              "variable": [
                {
                  "key": "id",
                  "value": "call-uuid-here"
                }
              ]
            },
            "description": "End an active call"
          }
        }
      ]
    },
