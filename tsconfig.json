{
  "include": ["client/src/**/*", "api/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "client/src/components/admin/**",
    "client/src/components/app-sidebar.tsx",
    "client/src/components/TeamMemberSidebar.tsx",
    "client/src/components/AdminTeamMemberSidebar.tsx",
    "client/src/components/plugin-bootstrapper.tsx",
    "client/src/components/AnalyticsChart.tsx",
    "client/src/components/Agent*.tsx",
    "client/src/components/Credit*.tsx",
    "client/src/components/LanguageSelector.tsx",
    "client/src/components/NotificationBell.tsx",
    "client/src/components/HeaderBannerNotifications.tsx",
    "client/src/components/DemoModeBanner.tsx",
    "client/src/components/PromptTemplatesLibrary.tsx",
    "client/src/components/TestFlowDialog.tsx",
    "client/src/components/Voice*.tsx",
    "client/src/components/PhoneConflictDialog.tsx",
    "client/src/components/TimezoneEnforcementModal.tsx",
    "client/src/components/SessionTimeoutDialog.tsx",
    "client/src/components/flow-automation/**",
    "client/src/contexts",
    "client/src/components/ui/chart.tsx",
    "client/src/hooks/useActivityTimeout.ts",
    "client/src/lib/auth-storage.ts",
    "client/src/lib/team-auth.ts",
    "client/src/pages/Admin*.tsx",
    "client/src/pages/Dashboard.tsx",
    "client/src/pages/HRAnalyticsPage.tsx",
    "client/src/pages/Billing.tsx",
    "client/src/pages/PaymentResult.tsx",
    "client/src/pages/Upgrade.tsx",
    "client/src/pages/KnowledgeBase.tsx",
    "client/src/pages/Agents.tsx",
    "client/src/pages/Voices.tsx",
    "client/src/pages/PhoneNumbers.tsx",
    "client/src/pages/Settings.tsx",
    "client/src/pages/InstallWizard.tsx",
    "client/src/pages/FlowsPage.tsx",
    "client/src/pages/WidgetsPage.tsx",
    "client/src/pages/Flow*.tsx",
    "client/src/pages/PromptTemplates.tsx",
    "client/src/pages/TransactionHistory.tsx",
    "client/src/pages/LoginPage.tsx",
    "client/src/pages/TeamMemberLogin.tsx",
    "client/src/pages/AdminTeamLogin.tsx",
    "client/src/pages/JobsPage.tsx",
    "client/src/pages/CandidatesPage.tsx",
    "client/src/pages/PipelinePage.tsx",
    "client/src/pages/CVUploadPage.tsx",
    "client/src/pages/InterviewsPage.tsx",
    "client/src/pages/WebhookConfigPage.tsx"
  ],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"]
    }
  }
}
